# Portkey AI Gateway Configuration Example
# Copy this file to .env and update with your actual values

# =============================================================================
# REQUIRED: Gateway Access
# =============================================================================

# Main Portkey Gateway URL (required for all demos)
# Get your route with: oc get route portkey-gateway -o jsonpath='{.spec.host}'
PORTKEY_GATEWAY_URL="https://your-gateway-route.apps.your.cluster.local/v1"

# =============================================================================
# REQUIRED: Demo Namespace
# =============================================================================

# Namespace where your Portkey gateway is deployed
DEMO_NAMESPACE="your-demo-namespace"

# Service names for demo scripts (override if your services have different names)
REDIS_SECRET_NAME="redis-secret"
REDIS_SERVICE_NAME="redis-service"

# =============================================================================
# REQUIRED FOR CACHING DEMOS: Redis Access
# =============================================================================

# Redis host (use service name if running in cluster)
REDIS_HOST="redis-service"
# Or for local development: REDIS_HOST="localhost" (with port-forward)

# Redis port (default: 6379)
REDIS_PORT="6379"

# Redis password (get from secret: oc get secret portkey-gateway-redis -o jsonpath='{.data.redis-password}' | base64 -d)
REDIS_PASSWORD="your-redis-password"

# =============================================================================
# OPTIONAL: Service Endpoints (Override default service names)
# =============================================================================

# Ollama service endpoint (for local LLM demos)
OLLAMA_SERVICE_HOST="http://ollama-service:11434"

# vLLM service endpoint (for local vLLM demos)
VLLM_SERVICE_HOST="http://vllm-service:8080/v1"

# =============================================================================
# OPTIONAL: RHOAI Integration
# =============================================================================

# RHOAI models namespace (where InferenceServices are deployed)
RHOAI_MODELS_NAMESPACE="rhoai-models"

# Primary RHOAI model endpoint (use short service names, not FQDNs)
RHOAI_VLLM_PRIMARY_HOST="http://your-model-service:8080/v1"
RHOAI_VLLM_PRIMARY_MODEL="your-model-name"

# Secondary RHOAI model endpoint (for fallback/load-balancing demos)
RHOAI_VLLM_SECONDARY_HOST="http://your-secondary-model:8080/v1"
RHOAI_VLLM_SECONDARY_MODEL="your-secondary-model-name"

# =============================================================================
# OPTIONAL: External LLM Providers (if not using local/RHOAI models)
# =============================================================================

# OpenAI
OPENAI_API_KEY="sk-your-openai-key"

# Anthropic
ANTHROPIC_API_KEY="sk-ant-your-anthropic-key"

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================

# For local development, you might need to port-forward services:
# kubectl port-forward svc/portkey-gateway 8080:8080
# kubectl port-forward svc/redis-service 6379:6379

# Then use localhost endpoints:
# PORTKEY_GATEWAY_URL="http://localhost:8080/v1"
# REDIS_HOST="localhost"